[Script]
http-response ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next) script-path = https://raw.githubusercontent.com/facecent/ProxyCent/main/JavaScript/YouTube_proto.js, requires-body = true, binary-body-mode = true, timeout = 10, tag = Proto处理

[MitM]
hostname = youtubei.googleapis.com
